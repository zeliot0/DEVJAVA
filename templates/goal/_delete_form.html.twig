{# templates/goal/_delete_form.html.twig #}
<form method="post" action="{{ path('app_goal_delete', {'id_g': goal.getIdGoa()}) }}" 
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet objectif ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ goal.getIdGoa()) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>