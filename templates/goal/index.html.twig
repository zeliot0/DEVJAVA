{# templates/goal/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Objectifs - NEXA{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="dashboard-header">
        <div>
            <h1><i class="fas fa-bullseye me-2"></i>NEXA Goals</h1>
            <p class="subtitle">Gestion intelligente de vos objectifs</p>
        </div>
        <a href="{{ path('app_goal_new') }}" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Nouvel objectif
        </a>
    </div>

    {% if goals is empty %}
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-bullseye"></i>
            </div>
            <h3>Aucun objectif trouvé</h3>
            <p>Vous n'avez pas encore créé d'objectifs. Commencez par en créer un pour suivre votre progression.</p>
            <a href="{{ path('app_goal_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Créer votre premier objectif
            </a>
        </div>
  {% else %}
    <div class="nexa-table-wrapper">
        <table class="nexa-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Statut</th>
                    <th>Priorité</th>
                    <th>Progression</th>
                    <th>Dates</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for goal in goals %}
                <tr>
                    <td>{{ goal.idGoa }}</td>

                    <td>
                        <strong>{{ goal.titleGoa }}</strong><br>
                        <small>
                            {{ goal.descriptionGoa|default('Aucune description')|slice(0, 50) }}
                            {% if goal.descriptionGoa|length > 50 %}...{% endif %}
                        </small>
                    </td>

                    <td>
                        <span class="badge">
                            {{ goal.statusGoa|default('N/A') }}
                        </span>
                    </td>

                    <td>{{ goal.priorityGoa|default('Moyenne') }}</td>

                    <td>
                        {% set p = goal.progressGoa|default(0) %}
                        
{% set p = goal.progressGoa|default(0) %}

<div class="nexa-progress-control">
    
    <!-- DOWN -->
    <form method="post" action="{{ path('app_goal_progress_down', {'id': goal.idGoa}) }}">
        <button class="progress-btn down">⬇</button>
    </form>

    <!-- BAR -->
    <div class="nexa-progress-wrapper">
        <div class="nexa-progress-fill
            {% if p == 100 %}progress-done
            {% elseif p > 70 %}progress-high
            {% elseif p > 30 %}progress-mid
            {% else %}progress-low{% endif %}"
            style="width: {{ p }}%">
        </div>
    </div>

    <!-- NUMBER -->
    <span class="nexa-progress-text">{{ p }}%</span>

    <!-- UP -->
    <form method="post" action="{{ path('app_goal_progress_up', {'id': goal.idGoa}) }}">
        <button class="progress-btn up">⬆</button>
    </form>

</div>

                    </td>

                    <td>
                        {{ goal.dateDebutGoa ? goal.dateDebutGoa|date('d/m/Y') : 'N/A' }}
                        →
                        {{ goal.dateFinalGoa ? goal.dateFinalGoa|date('d/m/Y') : 'N/A' }}
                    </td>

                    <td class="actions">
                        <a href="{{ path('app_goal_show', {'id_g': goal.idGoa}) }}" class="btn-action view" title="Voir">👁</a>
                        <a href="{{ path('app_goal_edit', {'id_g': goal.idGoa}) }}" class="btn-action edit" title="Modifier">✏️</a>

                        <form action="{{ path('app_goal_delete', {'id_g': goal.idGoa}) }}"
                              method="post"
                              style="display:inline;"
                              onsubmit="return confirm('Supprimer cet objectif ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ goal.idGoa) }}">
                            <button class="btn-action delete" title="Supprimer">🗑</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
</div>
{% endblock %}