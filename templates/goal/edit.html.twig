{% extends 'base.html.twig' %}

{% block title %}Modifier Objectif - NEXA{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="goal-card">
                <div class="goal-header">
                    <h1 class="goal-title mb-0">Modifier l'objectif</h1>
                </div>
                
                <div class="goal-content">
                    {{ include('goal/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
                    
                    <div class="mt-4 d-flex justify-content-between">
                        <a href="{{ path('app_goal_show', {'id_g': goal.id}) }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Retour aux détails
                        </a>
                        
                        {{ include('goal/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}