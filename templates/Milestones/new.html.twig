{% extends 'base.html.twig' %}

{% block title %}Nouveau Jalon - NEXA{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="goal-card">
                <div class="goal-header">
                    <h1 class="goal-title mb-0">Créer un nouveau jalon</h1>
                </div>
                
                <div class="goal-content">
                    {{ include('milestones/_form.html.twig') }}
                    
                    <div class="mt-4">
                        <a href="{{ path('app_milestones_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}