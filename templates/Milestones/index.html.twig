{# templates/Milestones/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Jalons{% endblock %}

{% block body %}
<div class="nexa-milestones-container">
    <div class="nexa-milestones-header">
        <div>
            <h2><i class="bi bi-flag"></i> Jalons</h2>
            <p class="nexa-form-subtitle">Suivez vos jalons et étapes importantes</p>
        </div>
        <a href="{{ path('app_milestones_new') }}" class="nexa-add-milestone-btn">
            <i class="bi bi-plus-circle"></i> Ajouter un jalon
        </a>
    </div>

    <div class="nexa-milestone-progress">
        <div class="nexa-milestone-progress-header">
            <h4 class="nexa-milestone-progress-title">Vos jalons</h4>
            <span class="nexa-milestone-progress-count">{{ milestones|length }} jalon(s)</span>
        </div>
    </div>

    <div class="nexa-milestones-list">
        {% for milestone in milestones %}
        <div class="nexa-milestone-card 
            {% if milestone.getStatus() == 'overdue' %}delayed
            {% elseif milestone.getStatus() == 'completed' %}completed
            {% else %}pending{% endif %}">
            
            <div class="nexa-milestone-content">
                <div class="nexa-milestone-icon 
                    {% if milestone.getStatus() == 'completed' %}completed
                    {% elseif milestone.getStatus() == 'overdue' %}delayed{% endif %}">
                    <i class="bi bi-flag"></i>
                </div>
                
                <div class="nexa-milestone-details">
                    <div class="nexa-milestone-header">
                        <h3 class="nexa-milestone-title">{{ milestone.title }}</h3>
                        <span class="nexa-milestone-status 
                            {% if milestone.getStatus() == 'completed' %}nexa-status-on-time
                            {% elseif milestone.getStatus() == 'overdue' %}nexa-status-delayed
                            {% else %}nexa-status-upcoming{% endif %}">
                            {% if milestone.getStatus() == 'completed' %}Terminé
                            {% elseif milestone.getStatus() == 'overdue' %}EN RETARD
                            {% elseif milestone.getStatus() == 'upcoming' %}À venir
                            {% else %}En attente{% endif %}
                        </span>
                    </div>
                    
                    <p class="nexa-milestone-description">{{ milestone.description }}</p>
                    
                    <div class="nexa-milestone-meta">
                        {% if milestone.dueDate %}
                        <div class="nexa-meta-item">
                            <i class="bi bi-calendar"></i>
                            <span>Échéance :</span>
                            <span class="nexa-meta-date {% if milestone.getStatus() == 'overdue' %}overdue{% endif %}">
                                {{ milestone.dueDate|date('d/m/Y') }}
                            </span>
                        </div>
                        {% endif %}
                        
                        {% if milestone.completedDate %}
                        <div class="nexa-meta-item">
                            <i class="bi bi-check-circle"></i>
                            <span>Terminé le :</span>
                            <span class="nexa-meta-date">{{ milestone.completedDate|date('d/m/Y') }}</span>
                        </div>
                        {% endif %}
                        
                        {% if milestone.goalGoa %}
                        <div class="nexa-meta-item">
                            <i class="bi bi-bullseye"></i>
                            <span>Objectif :</span>
                            <span class="nexa-meta-date">{{ milestone.goalGoa.titleGoa }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
                
                <div class="nexa-milestone-checkbox">
                    {% if milestone.completedDate %}
                    <div class="nexa-checkbox-custom checked">
                        <i class="bi bi-check"></i>
                    </div>
                    {% else %}
                    <div class="nexa-checkbox-custom">
                        <form method="post" action="{{ path('app_milestones_complete', {'id': milestone.id}) }}" 
                              class="d-inline" onsubmit="return confirm('Marquer ce jalon comme terminé ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('complete' ~ milestone.id) }}">
                            <button type="submit" class="nexa-checkbox-custom" style="border: none; background: none; cursor: pointer;">
                                <i class="bi bi-check"></i>
                            </button>
                        </form>
                    </div>
                    {% endif %}
                </div>
            </div>
            
            <div class="nexa-table-actions">
                <a href="{{ path('app_milestones_show', {'id': milestone.id}) }}" 
                   class="nexa-btn-action nexa-btn-view" title="Voir">
                    <i class="bi bi-eye"></i>
                </a>
                <a href="{{ path('app_milestones_edit', {'id': milestone.id}) }}" 
                   class="nexa-btn-action nexa-btn-edit" title="Modifier">
                    <i class="bi bi-pencil"></i>
                </a>
                <form method="post" action="{{ path('app_milestones_delete', {'id': milestone.id}) }}" 
                      class="d-inline" onsubmit="return confirm('Supprimer ce jalon ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ milestone.id) }}">
                    <button type="submit" class="nexa-btn-action nexa-btn-delete" title="Supprimer">
                        <i class="bi bi-trash"></i>
                    </button>
                </form>
            </div>
        </div>
        {% else %}
        <div class="nexa-milestones-empty">
            <i class="bi bi-flag"></i>
            <h3>Aucun jalon trouvé</h3>
            <p>Créez votre premier jalon pour suivre les étapes importantes de vos objectifs.</p>
            <a href="{{ path('app_milestones_new') }}" class="nexa-add-milestone-btn">
                <i class="bi bi-plus-circle"></i> Créer votre premier jalon
            </a>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}