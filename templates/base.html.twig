<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}NEXA - Goals Management{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- NEXA Custom CSS (LOAD AFTER Bootstrap) -->
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <link rel="stylesheet" href="{{ asset('css/nexa.css') }}">
    
    {% block stylesheets %}{% endblock %}
</head>

<body>

<div class="layout layout-pro" id="appLayout">

    <!-- Mobile overlay -->
    <div class="sb-overlay" id="sbOverlay"></div>

    <!-- ================= SIDEBAR ================= -->
    <aside class="sidebar sidebar-pro" id="sidebar">

        <div class="sb-head">
            <div class="sb-brand">
                <div class="sb-logo">
                    <i class="fa-solid fa-bolt"></i>
                </div>
                <div class="sb-txt">
                    <div class="sb-title">NEXA</div>
                    <div class="sb-sub">
                        <span class="dot-online"></span> Online
                    </div>
                </div>
            </div>

            <button class="sb-collapse" id="sbCollapse">
                <i class="fa-solid fa-angles-left"></i>
            </button>
        </div>

        <nav class="sb-nav">
            <div class="sb-section">Workspace</div>

            <a class="sb-item" href="{{ path('app_goal_index') }}">
                <i class="bi bi-speedometer2"></i>
                <span>Tableau de bord</span>
            </a>

            <a class="sb-item" href="{{ path('app_goal_index') }}">
                <i class="bi bi-bullseye"></i>
                <span>Objectifs</span>
            </a>

            {# CORRECTION : Utilisation correcte de la route #}
            <a class="sb-item" href="{{ path('app_milestones_index') }}">
                <i class="bi bi-flag"></i>
                <span>Jalons</span>
            </a>

            <a class="sb-item" href="#" onclick="alert('Statistiques - À venir bientôt!');">
                <i class="bi bi-graph-up"></i>
                <span>Statistiques</span>
            </a>

            {# CORRECTION : Utilisation correcte de la route #}
            <a class="sb-item" href="{{ path('app_motivation_index') }}">
                <i class="bi bi-lightbulb"></i>
                <span>Motivation</span>
            </a>

            <div class="sb-section">Paramètres</div>

            <a class="sb-item" href="#" onclick="alert('Catégories - À venir bientôt!');">
                <i class="bi bi-tags"></i>
                <span>Catégories</span>
            </a>

            <a class="sb-item" href="#" onclick="alert('Paramètres - À venir bientôt!');">
                <i class="bi bi-gear"></i>
                <span>Paramètres</span>
            </a>
        </nav>

        <div class="sb-profile">
            <div class="sb-prof-top">
                <div class="sb-avatar">NX</div>
                <div class="sb-prof-txt">
                    <div class="sb-prof-name">NEXA User</div>
                    <div class="sb-prof-role">Gestion des Objectifs</div>
                </div>
            </div>

            <button class="sb-logout" onclick="alert('Fonctionnalité de déconnexion - À implémenter');">
                <i class="bi bi-box-arrow-right"></i>
                <span>Déconnexion</span>
            </button>
        </div>

    </aside>

    <!-- ================= MAIN ================= -->
    <main class="main main-pro">

        <!-- TOPBAR -->
        <div class="topbar topbar-pro">
            <div class="top-left">
                <button class="btn icon-only" id="topSidebarBtn">
                    <i class="fa-solid fa-bars"></i>
                </button>

                <div class="brand-pro">
                    <div class="brand-name">NEXA Goals</div>
                    <div class="brand-sub">Gestion intelligente de vos objectifs</div>
                </div>
            </div>

            <div class="top-right">
                <div class="datetime-display me-3">
                    <span id="current-date"></span>
                    <span id="current-time" class="ms-2"></span>
                </div>

                <button class="toggle" id="themeToggle">
                    <i class="fa-solid fa-moon"></i>
                </button>

                <div class="dropdown ms-3">
                    <button class="btn icon-only" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        <span class="badge bg-danger">3</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li class="dropdown-header">Notifications</li>
                        <li><a class="dropdown-item" href="#">Nouvel objectif</a></li>
                        <li><a class="dropdown-item" href="#">Jalon à terminer</a></li>
                        <li><a class="dropdown-item" href="#">Objectif en retard</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="wrap">

        <!-- NEXA FLIP ANIMATION -->
<div class="nexa-flip-container">
    <span class="flip-static">Make</span>
    <div class="flip">
        <div><div>wOrK</div></div>
        <div><div>lifeStyle</div></div>
        <div><div>Everything</div></div>
    </div>
    <span class="flip-static">AweSoMe!</span>
</div>

            <div class="container-fluid mt-3">

                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="fas fa-check-circle me-2"></i>
                        {{ message }}
                        <button class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        {{ message }}
                        <button class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% for message in app.flashes('warning') %}
                    <div class="alert alert-warning alert-dismissible fade show">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        {{ message }}
                        <button class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% for message in app.flashes('info') %}
                    <div class="alert alert-info alert-dismissible fade show">
                        <i class="fas fa-info-circle me-2"></i>
                        {{ message }}
                        <button class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </div>

    </main>
</div>

<!-- ================= SCRIPTS ================= -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", () => {

    // Theme toggle
    const html = document.documentElement;
    const btn = document.getElementById("themeToggle");
    const icon = btn.querySelector("i");

    const saved = localStorage.getItem("theme") || "dark";
    html.setAttribute("data-theme", saved);
    icon.className = saved === "dark" ? "fa-solid fa-moon" : "fa-solid fa-sun";

    btn.addEventListener("click", () => {
        const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
        icon.className = next === "dark" ? "fa-solid fa-moon" : "fa-solid fa-sun";
    });

    // Date & time
    function updateDateTime() {
        const now = new Date();
        document.getElementById("current-date").textContent =
            now.toLocaleDateString("fr-FR", { weekday: "long", year: "numeric", month: "long", day: "numeric" });
        document.getElementById("current-time").textContent =
            now.toLocaleTimeString("fr-FR", { hour: '2-digit', minute: '2-digit' });
    }

    updateDateTime();
    setInterval(updateDateTime, 1000);

    // Sidebar collapse
    const sidebar = document.getElementById("sidebar");
    const sbCollapse = document.getElementById("sbCollapse");
    
    if (sbCollapse) {
        sbCollapse.addEventListener("click", () => {
            sidebar.classList.toggle("collapsed");
            localStorage.setItem("sidebarCollapsed", sidebar.classList.contains("collapsed"));
        });
    }

    if (localStorage.getItem("sidebarCollapsed") === "true") {
        sidebar.classList.add("collapsed");
    }

    // Mobile sidebar toggle
    const topSidebarBtn = document.getElementById("topSidebarBtn");
    const sbOverlay = document.getElementById("sbOverlay");
    
    if (topSidebarBtn && sbOverlay) {
        topSidebarBtn.addEventListener("click", () => {
            sidebar.classList.toggle("mobile-open");
            sbOverlay.classList.toggle("active");
        });
        
        sbOverlay.addEventListener("click", () => {
            sidebar.classList.remove("mobile-open");
            sbOverlay.classList.remove("active");
        });
    }

    // Auto-dismiss alerts after 5 seconds
    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(alert => {
            const bsAlert = new bootstrap.Alert(alert);
            bsAlert.close();
        });
    }, 5000);

    // Tooltips
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    const tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
    
    // Active menu item highlighting - Version améliorée
    const currentPath = window.location.pathname;
    document.querySelectorAll('.sb-item').forEach(item => {
        // Si l'item a un href et qu'il n'est pas juste '#' ou javascript
        if (item.href && item.href !== '#' && !item.href.includes('javascript:')) {
            try {
                const itemUrl = new URL(item.href);
                const itemPath = itemUrl.pathname;
                
                // Enlève le slash final pour la comparaison
                const cleanCurrentPath = currentPath.replace(/\/$/, '');
                const cleanItemPath = itemPath.replace(/\/$/, '');
                
                if (cleanCurrentPath === cleanItemPath || 
                    (cleanItemPath !== '/' && cleanCurrentPath.startsWith(cleanItemPath))) {
                    // Enlève la classe active de tous les items
                    document.querySelectorAll('.sb-item').forEach(i => i.classList.remove('active'));
                    // Ajoute la classe active à l'item courant
                    item.classList.add('active');
                }
            } catch (e) {
                console.error('Erreur URL:', e);
            }
        }
    });
    
    // Ajouter des indices visuels pour les liens temporaires
    document.querySelectorAll('.sb-item[href="#"]').forEach(item => {
        item.style.cursor = 'help';
        item.style.opacity = '0.7';
    });

    ///fun animation
});
</script>

{% block javascripts %}{% endblock %}

</body>
</html>